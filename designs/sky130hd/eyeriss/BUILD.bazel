load("//:defs.bzl", "hightide_design")

filegroup(
    name = "sram_lefs",
    srcs = glob(["sram/lef/*.lef"]),
)

filegroup(
    name = "sram_libs",
    srcs = glob(["sram/lib/*.lib"]),
)

# Eyeriss v2 sparse-CNN accelerator on sky130hd. Same RTL as asap7/nangate45
# but FakeRAMs regenerated for the 130nm metal stack via
# designs/sky130hd/eyeriss/sram/fakeram_sky130hd.cfg. The sky130hd memories
# are roughly 30x the asap7 area, so floorplan utilization is intentionally
# loose to give the placer room around ~157 macros.
hightide_design(
    name = "eyeriss",
    top = "TOP",
    platform = "sky130hd",
    verilog_files = ["//designs/src/eyeriss:rtl"],
    sources = {
        "SDC_FILE": [":constraint.sdc"],
        "ADDITIONAL_LEFS": [":sram_lefs"],
        "ADDITIONAL_LIBS": [":sram_libs"],
    },
    arguments = {
        "SYNTH_HIERARCHICAL": "1",
        # PPA round 2: prior util 30 / halo 30 closed setup at exactly
        # +2.8 ps (Fmax 40 MHz on 25 ns clock).  No clock headroom, but
        # the floorplan still has area to give: bump util 30→34 and
        # tighten halo 30→25 to shrink the die ~12 %.  Shorter wires on
        # the TOP_controller → pSumSRAM2 distribution signal should keep
        # setup positive even at the tighter util — if it goes red we'll
        # back the halo off in round 3.
        "CORE_UTILIZATION": "34",
        "PLACE_DENSITY_LB_ADDON": "0.15",
        "MACRO_PLACE_HALO": "25 25",
        "TNS_END_PERCENT": "100",
        # Same ODB-1200 pattern as asap7 — drop split_load from the move
        # sequence to keep the rest of repair_timing active.
        "SETUP_MOVE_SEQUENCE": "unbuffer,sizeup,swap,buffer,clone",
        # repair_timing non-convergence on the inter-cluster psum chains
        # (CLAUDE.md table; same pathology as asap7).
        "SKIP_INCREMENTAL_REPAIR": "1",
        "SKIP_LAST_GASP": "1",
    },
)
