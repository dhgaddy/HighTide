load("//:defs.bzl", "hightide_design")

package(default_visibility = ["//designs/asap7/litepci:__subpackages__"])

# FakeRAM macros for the five distinct memory geometries litepcie_core
# infers (1rw + 1r, sync read).  Generated by bsg_fakeram from
# designs/src/litepci/dev/generated/fakeram_asap7.cfg.
filegroup(
    name = "sram_lefs",
    srcs = glob(["sram/lef/*.lef"]),
)

filegroup(
    name = "sram_libs",
    srcs = glob(["sram/lib/*.lib"]),
)

# LitePCIe core (kcu105 / USPCIEPHY config) on asap7.
#
# The Xilinx PCIe hard IP (`pcie_us`) and the GT diff-clock buffer
# (`IBUFDS_GTE3`) are FPGA-only — the former is declared (* blackbox *)
# in pcie_us_stub.v, the latter has a synthesizable passthrough that
# maps to an ASAP7 BUFx2 via `USE_ASAP7_CELLS`.
hightide_design(
    name = "litepci",
    top = "litepcie_core",
    platform = "asap7",
    verilog_files = ["//designs/src/litepci:rtl"],
    sources = {
        "SDC_FILE": [":constraint.sdc"],
        "ADDITIONAL_LEFS": [":sram_lefs"],
        "ADDITIONAL_LIBS": [":sram_libs"],
    },
    arguments = {
        "VERILOG_DEFINES": "-D USE_ASAP7_CELLS",
        # Tuned across three rounds with mocked memories; will retune now
        # that dev/inline_fakeram.py wires the 20 DMA / TLP memories to real
        # FakeRAM instances and STA sees register-to-register paths again.
        "CORE_UTILIZATION": "60",
        "PLACE_DENSITY": "0.65",
        "MACRO_PLACE_HALO": "5 5",
        # Allow no GDS for fakeram macros and the pcie_us blackbox.
        "GDS_ALLOW_EMPTY": "fakeram.*|pcie_us",
        # ODB-1200 bug — InsertBufferBeforeLoads iterates a stale load list and
        # aborts when SplitLoadMove fires in repair_timing.  SETUP_MOVE_SEQUENCE
        # without split_load fixes the setup pass (same as gemmini-asap7 in
        # CLAUDE.md) but the *hold* pass inside the post-GRT repair_timing_helper
        # also calls split_load and crashes too.  Skip the whole post-GRT repair
        # block (matches snitch_cluster / liteeth_udp_sgmii in the table).
        "SETUP_MOVE_SEQUENCE": "unbuffer,sizeup,swap,buffer,clone",
        "SKIP_INCREMENTAL_REPAIR": "1",
    },
)
