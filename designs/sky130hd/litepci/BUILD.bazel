load("//:defs.bzl", "hightide_design")

package(default_visibility = ["//designs/sky130hd/litepci:__subpackages__"])

filegroup(
    name = "sram_lefs",
    srcs = glob(["sram/lef/*.lef"]),
)

filegroup(
    name = "sram_libs",
    srcs = glob(["sram/lib/*.lib"]),
)

# Placeholder LEF/LIB for the pcie_us Xilinx PCIe hard-IP blackbox.
# Committed (not regenerated at flow time) so synth_odb has a master for
# the blackbox; produced by designs/src/litepci/dev/gen_phy_lef.py via
# dev/gen.sh. See designs/src/litepci/BUILD.bazel.
filegroup(
    name = "phy_lefs",
    srcs = glob(["phy/lef/*.lef"]),
)

filegroup(
    name = "phy_libs",
    srcs = glob(["phy/lib/*.lib"]),
)

# LitePCIe core (kcu105 / USPCIEPHY config) on sky130hd.
# See designs/asap7/litepci/BUILD.bazel for the design-side rationale.
hightide_design(
    name = "litepci",
    top = "litepcie_core",
    platform = "sky130hd",
    verilog_files = ["//designs/src/litepci:rtl"],
    sources = {
        "SDC_FILE": [":constraint.sdc"],
        "ADDITIONAL_LEFS": [":sram_lefs", ":phy_lefs"],
        "ADDITIONAL_LIBS": [":sram_libs", ":phy_libs"],
        # Fixed-grid macro placement (every macro R0, channel below every
        # row).  RTLMP's pin-edge-blind, mixed-orientation clustering on
        # this sky130hd build collided adjacent macros' met2 escape lanes
        # -> 18 vertical met2 + 8 vertical met4 overflows clustered in a
        # ~200x150 um region around storage_23 et al, with GRT-0116 and
        # the standard "Try reduce the layer adjustment 20%->11%" hint
        # that knob-tuning alone can't satisfy here (overall track usage
        # was 5.85%, so it's structural not bulk congestion).  Same
        # idiom as cnn-sky130hd, NVDLA-sky130hd-partition_c (CLAUDE.md
        # MPL-0040 row).  Generated via:
        #   tools/gen_macro_grid.py <dump> macros.tcl --chan 200 --gap-x 100
        # (chan/gap tightened vs the cnn defaults to fit a 10.3 mm core
        # given litepci's 21 macros incl. 2 tall 1024d FakeRAMs.)
        "MACRO_PLACEMENT_TCL": [":macros.tcl"],
    },
    arguments = {
        "VERILOG_DEFINES": "-D USE_SKY130HD_CELLS",
        # Real-FakeRAM build with fixed-grid macro placement (see
        # sources.MACRO_PLACEMENT_TCL above).  util 30 / density 0.40 /
        # halo 100 retained as the starting point; halo less critical now
        # that the grid pins every macro FIRM and the post-source
        # rtl_macro_placer has no work to do.
        "CORE_UTILIZATION": "30",
        "PLACE_DENSITY": "0.40",
        "MACRO_PLACE_HALO": "100 100",
        "GDS_ALLOW_EMPTY": "fakeram.*|pcie_us",
        # ODB-1200 — drop split_load from SETUP_MOVE_SEQUENCE; skip the
        # post-GRT repair_timing block.  Same workaround as asap7 litepci.
        "SETUP_MOVE_SEQUENCE": "unbuffer,sizeup,swap,buffer,clone",
        "SKIP_INCREMENTAL_REPAIR": "1",
    },
)
